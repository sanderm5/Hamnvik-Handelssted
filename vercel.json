{
  "redirects": [
    { "source": "/krambu", "destination": "/", "permanent": true },
    { "source": "/overnatting", "destination": "/", "permanent": true },
    { "source": "/om-oss", "destination": "/historie", "permanent": true },
    { "source": "/nyheter", "destination": "/program", "permanent": true },
    { "source": "/bilder", "destination": "/arkiv", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://core.sanity-cdn.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://cdn.sanity.io https://avatars.githubusercontent.com; connect-src 'self' https://*.sanity.io https://*.api.sanity.io https://sanity-cdn.com; frame-ancestors https://*.sanity.studio https://hamnvik-handelssted.vercel.app" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*)\\.webp",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
