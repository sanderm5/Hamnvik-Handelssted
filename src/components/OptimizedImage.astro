---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  sizes?: string;
  class?: string;
  fetchpriority?: 'high' | 'low' | 'auto';
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  sizes,
  class: className,
  fetchpriority,
} = Astro.props;

const webp = src.replace(/\.(jpg|jpeg|png)$/i, '.webp');
---

<picture>
  <source srcset={webp} type="image/webp" />
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    sizes={sizes}
    class={className}
    fetchpriority={fetchpriority}
  />
</picture>
