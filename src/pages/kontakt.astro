---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt" currentPath="/kontakt">
  <main id="main-content" class="main-content">
    <h1>Kontakt oss</h1>
    <p class="article-deck">Henvendelser om servering, overnatting, selskaper og omvisning</p>
    <p class="byline">Donseg&aring;rden &middot; Hamnvik, Ibestad</p>

    <p class="page-intro">
      Vi tar gjerne imot henvendelser om servering, overnatting, selskaper
      eller bare en hyggelig prat om stedet. Ring eller skriv &mdash; vi svarer
      så snart vi kan.
    </p>

    <div class="contact-grid">
      <div class="contact-card">
        <h3>Gunn Torild Dons</h3>
        <p><a href="mailto:g.t.dons@online.no">g.t.dons@online.no</a></p>
        <p><a href="tel:+4741806970">418 06 970</a></p>
      </div>
      <div class="contact-card">
        <h3>Einar Johan Dons</h3>
        <p><a href="mailto:e.j.dons@online.no">e.j.dons@online.no</a></p>
        <p><a href="tel:+4797640360">976 40 360</a></p>
      </div>
    </div>

    <hr class="divider" />

    <div class="notice-box" style="max-width: 400px; margin: 1.2rem auto;">
      <h3>Hamnvik Handelssted</h3>
      <p><a href="mailto:post@hamnvikhandelssted.com">post@hamnvikhandelssted.com</a></p>
      <p>Hamnvik, Ibestad kommune</p>
      <p>Troms</p>
    </div>

    <hr class="divider" />

    <h2 class="section-heading">Finn oss</h2>
    <p>
      Hamnvik Handelssted ligger i Hamnvik i Ibestad kommune, Troms.
      Handelsstedet er lett synlig fra sjøsiden med sine gule sjøhus langs brygga.
    </p>

    <figure class="vintage-frame straight" style="max-width: 100%;">
      <img src="/images/IMG_1853.jpg" alt="Hamnvik Handelssted sett fra sjøen med gule sjøhus" />
      <figcaption class="vintage-frame-caption">De gule sjøhusene ved brygga &mdash; velkommen til oss</figcaption>
    </figure>
  </main>
</BaseLayout>
