---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { reader } from '../utils/reader';

const overnatting = await reader.singletons.overnatting.read();
if (!overnatting) throw new Error('Overnatting-innhold mangler');
---

<BaseLayout title="Overnatting" currentPath="/overnatting">
  <main id="main-content" class="main-content">
    <h1>{overnatting.heading}</h1>
    <p class="article-deck">{overnatting.deck}</p>
    <p class="byline">{overnatting.byline}</p>

    <p class="page-intro">{overnatting.intro}</p>

    {overnatting.sections.map((section, i) => (
      <>
        {i > 0 && <hr class="divider" />}
        <Section section={section} />
      </>
    ))}

    <h3>Priser</h3>
    <ul>
      {overnatting.priser.map((p) => (
        <li>{p.label}: <strong>{p.price}</strong></li>
      ))}
    </ul>
    <p>{overnatting.prisNotat}</p>

    <div class="notice-box">
      <h3>{overnatting.noticeTitle}</h3>
      <p><a href="/kontakt">{overnatting.noticeText}</a></p>
    </div>
  </main>
</BaseLayout>
