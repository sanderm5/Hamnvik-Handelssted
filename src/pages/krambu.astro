---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { reader } from '../utils/reader';

const krambu = await reader.singletons.krambu.read();
if (!krambu) throw new Error('Krambu-innhold mangler');
---

<BaseLayout title="Krambu" currentPath="/krambu">
  <main id="main-content" class="main-content">
    <h1>{krambu.heading}</h1>
    <p class="article-deck">{krambu.deck}</p>
    <p class="byline">{krambu.byline}</p>

    <p class="page-intro">{krambu.intro}</p>

    {krambu.sections.map((section, i) => (
      <>
        {i > 0 && <hr class="divider" />}
        <Section section={section} />
      </>
    ))}

    <div class="notice-box notice-box-small">
      <h3>{krambu.noticeTitle}</h3>
      <p><a href="/kontakt">{krambu.noticeText}</a></p>
    </div>
  </main>
</BaseLayout>
