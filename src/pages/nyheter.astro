---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { reader } from '../utils/reader';

const allArticles = await reader.collections.nyheter.all();
---

<BaseLayout title="Nyheter" currentPath="/nyheter" description="Nyheter og aktuelt fra Hamnvik Handelssted i Ibestad, Troms.">
  <main id="main-content" class="main-content">
    <h1>Nyheter</h1>
    <p class="article-deck">Hendelser og øyeblikk fra livet på handelsstedet</p>
    <p class="byline">Redaksjonen &middot; Hamnvik</p>

    {allArticles.map((article, idx) => (
      <>
        {idx > 0 && <hr class="divider-heavy" />}

        <article>
          <h2 class="section-heading">{article.entry.title}</h2>
          {article.entry.deck && <p class="article-deck">{article.entry.deck}</p>}
          {article.entry.byline && <p class="byline">{article.entry.byline}</p>}

          <p class="drop-cap">{article.entry.intro}</p>

          {article.entry.sections.map((section) => (
            <Section section={section} />
          ))}

          {article.entry.galleryImages.length > 0 && (
            <>
              <hr class="divider" />
              <h3>Bilder fra dagen</h3>
              {article.entry.photoCredit && <p class="photo-credit">{article.entry.photoCredit}</p>}
              <div class="image-gallery">
                {article.entry.galleryImages.map((img) => (
                  <figure class="vintage-frame">
                    <picture>
                      <source srcset={img.image.replace(/\.jpg$/, '.webp')} type="image/webp" />
                      <img src={img.image} alt={img.alt} loading="lazy" decoding="async" />
                    </picture>
                  </figure>
                ))}
              </div>
            </>
          )}
        </article>
      </>
    ))}
  </main>
</BaseLayout>
