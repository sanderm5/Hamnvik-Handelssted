---
import BaseLayout from '../layouts/BaseLayout.astro';
import { reader } from '../utils/reader';

const omOss = await reader.singletons.omOss.read();
if (!omOss) throw new Error('Om oss-innhold mangler');
---

<BaseLayout title="Om oss" currentPath="/om-oss" description="Historien om Hamnvik Handelssted og Donsegården – et fredet handelssted fra 1794 i Ibestad kommune, Troms.">
  <main id="main-content" class="main-content">
    <h1>{omOss.heading}</h1>
    <p class="article-deck">{omOss.deck}</p>
    <p class="byline">{omOss.byline}</p>

    <p class="page-intro">{omOss.intro}</p>

    <div class="columns-2">
      <p>{omOss.introBody}</p>
    </div>

    <blockquote class="pull-quote">{omOss.pullQuote1}</blockquote>

    {omOss.sections.map((section, i) => (
      <>
        <hr class="divider" />

        <h2 class="section-heading">{section.heading}</h2>

        {section.image ? (
          <div style="display: flex; gap: 2rem; flex-wrap: wrap; align-items: flex-start;">
            <div style="flex: 1; min-width: 250px;">
              {section.content.split('\n\n').map((p, j) => (
                <p class={j === 0 ? 'drop-cap' : ''}>{p}</p>
              ))}
            </div>
            {section.imageCaption ? (
              <figure class="vintage-frame" style="max-width: 280px;">
                <img src={section.image} alt={section.imageAlt} />
                <figcaption class="vintage-frame-caption">{section.imageCaption}</figcaption>
              </figure>
            ) : (
              <figure class="vintage-frame straight" style="max-width: 100%;">
                <img src={section.image} alt={section.imageAlt} />
                <figcaption class="vintage-frame-caption">{section.imageCaption}</figcaption>
              </figure>
            )}
          </div>
        ) : section.content.includes('\n\n') ? (
          <div class="columns-2">
            {section.content.split('\n\n').map((p, j) => (
              <p class={j === 0 ? 'drop-cap' : ''}>{p}</p>
            ))}
          </div>
        ) : (
          <p class="drop-cap">{section.content}</p>
        )}

        {section.pullQuote && (
          <blockquote class="pull-quote">{section.pullQuote}</blockquote>
        )}
      </>
    ))}
  </main>
</BaseLayout>
