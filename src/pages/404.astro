---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Siden finnes ikke" currentPath="/404" description="Siden du leter etter finnes ikke på hamnvikhandelssted.com.">
  <main id="main-content" class="main-content error-page">
    <h1>Siden finnes ikke</h1>
    <p class="page-intro">Vi finner dessverre ikke siden du leter etter. Den kan ha blitt flyttet, slettet eller aldri ha eksistert.</p>

    <hr class="divider" />

    <h2 class="section-heading">Hva kan du gj&oslash;re?</h2>
    <ul>
      <li>G&aring; tilbake til <a href="/">forsiden</a></li>
      <li>Utforsk <a href="/servering">servering</a>, <a href="/overnatting">overnatting</a> eller <a href="/krambu">krambu</a></li>
      <li><a href="/kontakt">Ta kontakt</a> om du trenger hjelp</li>
    </ul>
  </main>
</BaseLayout>
