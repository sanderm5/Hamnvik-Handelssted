---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath = '/' } = Astro.props;
---

<!DOCTYPE html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Hamnvik Handelssted - Donsegården. Fredet handelssted fra 1794 i Ibestad kommune. Servering, overnatting, kulturformidling og krambu." />
    <link rel="icon" type="image/png" href="/images/4_stamp_ship.png" />
    <title>{title} | Hamnvik Handelssted</title>
    <ClientRouter />
  </head>
  <body>
    <div class="site-wrapper">
      <Header currentPath={currentPath} />
      <div transition:name="page-content">
        <slot />
      </div>
      <Footer />
    </div>

    <script>
      (function() {
        var dominated = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var mobile = window.matchMedia('(max-width: 750px)').matches;
        var seen = sessionStorage.getItem('hh-entered');

        if (!dominated && !mobile && !seen) {
          document.body.classList.add('entrance-active');
          sessionStorage.setItem('hh-entered', '1');
          setTimeout(function() {
            document.body.classList.remove('entrance-active');
          }, 2500);
        }
      })();
    </script>
  </body>
</html>
