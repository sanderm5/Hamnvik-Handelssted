---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileContactBar from '../components/MobileContactBar.astro';
import '../styles/global.css';

// Self-hosted fonts — only weights actually used in CSS
// Playfair Display: h1 (900-italic), drop-cap (900), h3 (700-italic)
import '@fontsource/playfair-display/900.css';
import '@fontsource/playfair-display/700-italic.css';
import '@fontsource/playfair-display/900-italic.css';
// Playfair Display SC: h2 / section headings (700)
import '@fontsource/playfair-display-sc/700.css';
// Cormorant Garamond: body (500), italic (500-italic), UI (600), bold (700)
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/cormorant-garamond/500-italic.css';
// Cormorant SC: subtitle (400), nav/labels (600)
import '@fontsource/cormorant-sc/400.css';
import '@fontsource/cormorant-sc/600.css';

interface Props {
  title: string;
  currentPath?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
  showBooking?: boolean;
}

const { title, currentPath = '/', description, ogImage, jsonLd, showBooking = false } = Astro.props;
const isFrontPage = currentPath === '/';

const siteName = 'Hamnvik Handelssted';
const siteUrl = 'https://hamnvikhandelssted.com';
const defaultDescription = 'Hamnvik Handelssted - Donsegården. Fredet handelssted fra 1794 i Ibestad kommune. Servering, overnatting, kulturformidling og krambu.';
const pageDescription = description || defaultDescription;
const canonicalUrl = `${siteUrl}${currentPath}`;
const pageOgImage = ogImage || `${siteUrl}/images/HAMNVIK.png`;
const fullTitle = `${title} | ${siteName}`;
---

<!DOCTYPE html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/png" href="/images/4_stamp_ship.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="canonical" href={canonicalUrl} />

    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nb_NO" />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageOgImage} />

    <meta name="theme-color" content="#f6f0e0" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1610" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href="/images/4_stamp_ship.png" />

    {isFrontPage && (
      <link rel="preload" as="image" type="image/webp" href="/images/HAMNVIK.webp" />
    )}

    {isFrontPage && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Hamnvik Handelssted",
        "description": defaultDescription,
        "url": siteUrl,
        "image": `${siteUrl}/images/HAMNVIK.png`,
        "email": "post@hamnvikhandelssted.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Hamnvik",
          "addressLocality": "Ibestad",
          "addressRegion": "Troms",
          "addressCountry": "NO"
        },
        "foundingDate": "1794",
        "additionalType": [
          "https://schema.org/Restaurant",
          "https://schema.org/LodgingBusiness",
          "https://schema.org/Store"
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Tjenester",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Servering" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Overnatting" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kulturformidling" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Krambu" } }
          ]
        }
      })} />
    )}

    {!isFrontPage && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Hjem",
            "item": siteUrl
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": title,
            "item": canonicalUrl
          }
        ]
      })} />
    )}

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <noscript><style>.scroll-reveal{opacity:1;transform:none}</style></noscript>
    <ClientRouter />
    <script is:inline>
      // Apply theme immediately to prevent flash
      (function() {
        var setting = localStorage.getItem('theme') || 'system';
        var html = document.documentElement;
        html.setAttribute('data-theme-setting', setting);
        var isDark = setting === 'dark' || (setting === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        if (isDark) {
          html.setAttribute('data-theme', 'dark');
        } else {
          html.removeAttribute('data-theme');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Hopp til hovedinnhold</a>
    <div class="site-wrapper">
      <Header currentPath={currentPath} isFrontPage={isFrontPage} showBooking={showBooking} />
      <div class="page-content" transition:name="page-content">
        <slot />
      </div>
      <Footer />
    </div>
    <div class="nav-overlay"></div>
    <MobileContactBar />

    <script>
      import '../scripts/init';
    </script>
  </body>
</html>
